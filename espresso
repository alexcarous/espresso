#!/bin/zsh
args=()
display_msg=""

while [[ "$1" == -* ]]; do
    case "$1" in
        -d|--display)
            args+=("-d")
            display_msg=" (display forced on)"
            shift ;;
        -h|--help)
            echo "Usage: espresso [-d|--display] [hours minutes | stop | status]"
            exit 0 ;;
        *)
            echo "Error: Unknown flag $1"
            exit 1 ;;
    esac
done

case "$1" in
    stop)
        pkill -u "$USER" -x caffeinate && echo "Sleep prevention stopped." || echo "No active process found."
        exit 0 ;;
    status)
        pgrep -u "$USER" -x caffeinate >/dev/null 2>&1 && echo "Status: Active" || echo "Status: Inactive"
        exit 0 ;;
esac

if pgrep -u "$USER" -x caffeinate >/dev/null 2>&1; then
    pid=$(pgrep -u "$USER" -x caffeinate | head -n 1)
    total_sec=$(ps -p "$pid" -o args= | grep -oE '\-t\s+[0-9]+' | awk '{print $2}')
    elapsed_sec=$(ps -p "$pid" -o etimes= | tr -d ' ')

    if [[ -n "$total_sec" && "$total_sec" =~ ^[0-9]+$ && -n "$elapsed_sec" && "$elapsed_sec" =~ ^[0-9]+$ ]]; then
        rem_sec=$(( total_sec - elapsed_sec ))
        if (( rem_sec < 0 )); then
            rem_sec=0
        fi
        rem_hours=$(( rem_sec / 3600 ))
        rem_minutes=$(( (rem_sec % 3600) / 60 ))
        time_string="${rem_hours} hours and ${rem_minutes} minutes"
        
        echo "To run espresso, either wait $time_string or run the command \"pkill caffeinate\" to kill the existing process now."
    else
        echo "To run espresso, you must first run the command \"pkill caffeinate\" to kill the existing process now."
    fi
    exit 1
fi

hours=$1
minutes=$2

if [[ -z "$hours" ]]; then
    echo "Welcome to espresso. ☕️"
    echo ""
    read -r "hours?Enter hours: "
fi
[[ -z "$minutes" ]] && read -r "minutes?Enter minutes: "
hours=${hours:-0}
minutes=${minutes:-0}

if [[ ! "$hours" =~ ^[0-9]+$ || ! "$minutes" =~ ^[0-9]+$ || "$hours" -gt 8760 || "$minutes" -gt 59 ]]; then
    echo "Error: Valid integers required (hours <= 8760, minutes <= 59)."
    exit 1
fi

total_seconds=$(( (hours * 3600) + (minutes * 60) ))

if (( total_seconds > 0 )); then
    echo "System awake active${display_msg} for ${hours}h ${minutes}m."
    args+=("-t" "$total_seconds")
    caffeinate "${args[@]}" >/dev/null 2>&1 &!
    exit 0
fi

echo "Error: Duration must be greater than zero."
exit 1
